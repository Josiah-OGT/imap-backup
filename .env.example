# =============================================================================
# imap-backup configuration. Copy to `.env` and edit. Keep `.env` out of git.
# =============================================================================

# ---- Global behaviour --------------------------------------------------------
SYNC_INTERVAL=1h          # time between backup cycles: 30, 30m, 1h, 6h, 1d ...
RETAIN_DELETED=true       # true = archival (keep mail deleted on the server)
                          # false = exact mirror (propagate deletions to disk)

# ---- Logging -----------------------------------------------------------------
LOG_DIR=/logs             # mounted path inside the container
LOG_MAX_SIZE=10M          # rotate the logfile once it exceeds this
LOG_KEEP=7                # number of rotated logs to keep
LOG_TIMESTAMPS=true       # prefix log lines with ISO timestamps
LOG_COMPRESS=false        # gzip rotated logs

# ---- Restore behaviour -------------------------------------------------------
RESTORE_PRESYNC=false     # true = pull latest from SOURCE before restoring

# =============================================================================
# Accounts: one numbered block per mailbox. Indices need not be contiguous;
# every N with ACCOUNT_N_USER set is picked up automatically.
#
# Required: ACCOUNT_N_HOST, ACCOUNT_N_USER, ACCOUNT_N_PASS
# Optional: ACCOUNT_N_PORT  (default 993)
#           ACCOUNT_N_TLS   (default IMAPS; also STARTTLS or None)
#           ACCOUNT_N_NAME  (backup folder name; default = the address)
#           ACCOUNT_N_PASSCMD  (shell cmd that prints the password; replaces PASS)
# Restore target (optional; falls back to the source values above if unset):
#           ACCOUNT_N_RESTORE_HOST / _PORT / _USER / _PASS / _TLS / _PASSCMD
# =============================================================================

# ---- Account 1 ----
ACCOUNT_1_HOST=imap.gmail.com
ACCOUNT_1_PORT=993
ACCOUNT_1_USER=alice@gmail.com
ACCOUNT_1_PASS=app-password-here
# ACCOUNT_1_NAME=alice-gmail
# ACCOUNT_1_RESTORE_HOST=imap.newserver.com
# ACCOUNT_1_RESTORE_USER=alice@newserver.com
# ACCOUNT_1_RESTORE_PASS=new-password

# ---- Account 2 ----
ACCOUNT_2_HOST=outlook.office365.com
ACCOUNT_2_USER=bob@contoso.com
ACCOUNT_2_PASS=secret2
# (no RESTORE_* vars => restore would fall back to the source host/credentials)
